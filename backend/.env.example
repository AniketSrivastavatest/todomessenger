PORT=8787
PUBLIC_BACKEND_URL=http://localhost:8787
FRONTEND_ORIGIN=http://localhost:8080

# Use DATABASE_URL, or use the POSTGRES_* fields below.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/todomessenger
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=todomessenger
POSTGRES_SSL=false
POSTGRES_CONNECTION_LIMIT=10

# Development only. In production, omit this and send codes by email.
DEV_AUTH_CODE=123456

# Blu AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Asana OAuth
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=http://localhost:8787/oauth/asana/callback
ASANA_SCOPES=tasks:read tasks:write projects:read projects:write

# Jira OAuth
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8787/oauth/jira/callback
JIRA_SCOPES=read:jira-work write:jira-work offline_access
JIRA_CLOUD_ID=
JIRA_PROJECT_KEY=

# Token encryption for production integration tokens.
# Use a 32-byte key generated with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
TOKEN_ENCRYPTION_KEY=
